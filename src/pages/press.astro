---
import BaseLayout from '../layouts/BaseLayout.astro';
import SocialLinks from '../components/SocialLinks.astro';

const studioAssets = [
  { src: '/images/press/studio/logo-wide-400x200.png', label: 'Logo Wide', dim: '400x200' },
  { src: '/images/press/studio/logo-square-400x400.png', label: 'Logo Square', dim: '400x400' },
  { src: '/images/press/studio/logo-symbol-400x400.png', label: 'Logo Symbol', dim: '400x400' },
  { src: '/images/press/studio/youtube-banner-2048x1152.png', label: 'YouTube Banner', dim: '2048x1152' },
  { src: '/images/press/studio/linkedin-banner-1128x191.png', label: 'LinkedIn Banner', dim: '1128x191' },
];

const dissonantScreenshots = [
  { src: '/images/press/dissonant/dissonant-01.png', label: 'Screenshot 01' },
  { src: '/images/press/dissonant/dissonant-02.png', label: 'Screenshot 02' },
  { src: '/images/press/dissonant/dissonant-03.png', label: 'Screenshot 03' },
  { src: '/images/press/dissonant/dissonant-04.png', label: 'Screenshot 04' },
  { src: '/images/press/dissonant/dissonant-05.png', label: 'Screenshot 05' },
  { src: '/images/press/dissonant/dissonant-06.png', label: 'Screenshot 06' },
];

const dissonantCharacters = [
  { src: '/images/press/dissonant/vil-blue-mode.png', label: 'Vil - Blue Mode' },
  { src: '/images/press/dissonant/vil-red-mode.png', label: 'Vil - Red Mode' },
];

const dissonantSteam = [
  { src: '/images/press/dissonant/DissonantLogo_800x300.png', label: 'Game Logo', dim: '800x300' },
  { src: '/images/press/dissonant/dissonant-icon.png', label: 'Icon', dim: 'Square' },
  { src: '/images/press/dissonant/main-capsule-1232x706.png', label: 'Main Capsule', dim: '1232x706' },
  { src: '/images/press/dissonant/header-capsule-920x430.png', label: 'Header Capsule', dim: '920x430' },
  { src: '/images/press/dissonant/library-capsule-600x900.png', label: 'Library Capsule', dim: '600x900' },
  { src: '/images/press/dissonant/library-header-920x430.png', label: 'Library Header', dim: '920x430' },
  { src: '/images/press/dissonant/library-hero-3840x1240.png', label: 'Library Hero', dim: '3840x1240' },
  { src: '/images/press/dissonant/library-logo.png', label: 'Library Logo', dim: 'Transparent' },
  { src: '/images/press/dissonant/vertical-capsule-748x896.png', label: 'Vertical Capsule', dim: '748x896' },
  { src: '/images/press/dissonant/small-capsule-462x174.png', label: 'Small Capsule', dim: '462x174' },
  { src: '/images/press/dissonant/page-background-1438x810.png', label: 'Page Background', dim: '1438x810' },
];

const krodhaScreenshots = [
  { src: '/images/press/krodha/krodha-01.png', label: 'Screenshot 01' },
  { src: '/images/press/krodha/krodha-02.png', label: 'Screenshot 02' },
  { src: '/images/press/krodha/krodha-05.png', label: 'Screenshot 03' },
  { src: '/images/press/krodha/krodha-06.png', label: 'Screenshot 04' },
];

const krodhaSteam = [
  { src: '/images/press/krodha/krodha-logo-800x300.png', label: 'Game Logo', dim: '800x300' },
  { src: '/images/press/krodha/krodha-icon.png', label: 'Icon', dim: 'Square' },
  { src: '/images/press/krodha/main-capsule-1232x706.png', label: 'Main Capsule', dim: '1232x706' },
  { src: '/images/press/krodha/header-capsule-920x430.png', label: 'Header Capsule', dim: '920x430' },
  { src: '/images/press/krodha/library-capsule-600x900.png', label: 'Library Capsule', dim: '600x900' },
  { src: '/images/press/krodha/library-header-920x430.png', label: 'Library Header', dim: '920x430' },
  { src: '/images/press/krodha/library-hero-3840x1240.png', label: 'Library Hero', dim: '3840x1240' },
  { src: '/images/press/krodha/library-logo.png', label: 'Library Logo', dim: 'Transparent' },
  { src: '/images/press/krodha/vertical-capsule-748x896.png', label: 'Vertical Capsule', dim: '748x896' },
  { src: '/images/press/krodha/small-capsule-462x174.png', label: 'Small Capsule', dim: '462x174' },
  { src: '/images/press/krodha/page-background-1438x810.png', label: 'Page Background', dim: '1438x810' },
];
---

<BaseLayout title="Press Kit · !How Game Studio" description="Press kit for !How Game Studio. Download logos, screenshots, and brand assets.">
  <!-- HERO -->
  <section class="bg-crimson pt-32 pb-20 px-6 text-center relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-16 right-20 w-48 h-48 border border-white/5 rounded-full"></div>
      <div class="absolute bottom-8 left-16 w-32 h-32 border border-white/5 rotate-12"></div>
    </div>
    <h1 class="split-text font-display text-white text-[56px] md:text-[72px] leading-none relative z-10">PRESS KIT</h1>
    <p class="font-body text-snow/80 text-lg mt-4 relative z-10 fade-in">Everything you need to write about us.</p>
  </section>

  <!-- QUICK INFO -->
  <section class="bg-charcoal py-16 px-6 border-b border-fade">
    <div class="max-w-5xl mx-auto fade-in">
      <div class="grid md:grid-cols-2 gap-12">
        <div>
          <h2 class="font-display text-snow text-[32px] mb-6">STUDIO FACTS</h2>
          <dl class="space-y-4">
            <div class="flex gap-4">
              <dt class="text-mint font-body font-medium text-sm uppercase tracking-wider w-32 shrink-0">Studio</dt>
              <dd class="text-snow font-body">!How Game Studio</dd>
            </div>
            <div class="flex gap-4">
              <dt class="text-mint font-body font-medium text-sm uppercase tracking-wider w-32 shrink-0">Based in</dt>
              <dd class="text-snow font-body">India</dd>
            </div>
            <div class="flex gap-4">
              <dt class="text-mint font-body font-medium text-sm uppercase tracking-wider w-32 shrink-0">Founded</dt>
              <dd class="text-snow font-body">Independent Indie Studio</dd>
            </div>
            <div class="flex gap-4">
              <dt class="text-mint font-body font-medium text-sm uppercase tracking-wider w-32 shrink-0">Team Size</dt>
              <dd class="text-snow font-body">3 members</dd>
            </div>
            <div class="flex gap-4">
              <dt class="text-mint font-body font-medium text-sm uppercase tracking-wider w-32 shrink-0">Press Contact</dt>
              <dd class="text-mint font-body">press@howgamestudio.com</dd>
            </div>
          </dl>
        </div>
        <div>
          <h2 class="font-display text-snow text-[32px] mb-6">OUR GAMES</h2>
          <div class="space-y-4">
            <div class="bg-surface rounded-lg p-4 border border-fade">
              <h3 class="font-display text-snow text-xl">DISSONANT</h3>
              <p class="text-smoke text-sm mt-1">A patience test disguised as a game. Puzzle / Arcade / Souls-like.</p>
              <p class="text-mint text-xs mt-2 font-body font-medium uppercase tracking-wider">Coming Soon on Steam</p>
            </div>
            <div class="bg-surface rounded-lg p-4 border border-fade">
              <h3 class="font-display text-snow text-xl">KRODHA</h3>
              <p class="text-smoke text-sm mt-1">Anger forged into something worth fighting for. Action / Indie.</p>
              <p class="text-mint text-xs mt-2 font-body font-medium uppercase tracking-wider">Early Access Coming Soon</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- STUDIO DESCRIPTION -->
  <section class="bg-charcoal py-16 px-6 border-b border-fade">
    <div class="max-w-5xl mx-auto fade-in">
      <h2 class="font-display text-snow text-[32px] mb-6">ABOUT THE STUDIO</h2>
      <div class="bg-surface rounded-xl border border-fade p-8">
        <p class="text-smoke text-base leading-relaxed mb-4">
          !How Game Studio is an independent game development studio based in India. We build games that don't play it safe. We believe in deliberate design, earned difficulty, and the kind of experiences that stay with you after you close the game.
        </p>
        <p class="text-smoke text-base leading-relaxed">
          No publishers. No compromises. Every pixel is ours. The name says it all: we don't do things the expected way.
        </p>
        <p class="text-fade text-sm mt-6 italic">Feel free to use this description in articles and coverage.</p>
      </div>
    </div>
  </section>

  <!-- STUDIO LOGOS & BRANDING -->
  <section class="bg-charcoal py-20 px-6 border-b border-fade spotlight-section">
    <div class="max-w-5xl mx-auto">
      <div class="flex items-center justify-between mb-10">
        <h2 class="split-text font-display text-snow text-[36px]">STUDIO LOGOS & BRANDING</h2>
        <p class="text-fade text-sm font-body hidden md:block">Right-click to save</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 stagger-children">
        {studioAssets.map(asset => (
          <a href={asset.src} target="_blank" class="group">
            <div class="bg-surface rounded-xl border border-fade overflow-hidden hover:border-mint transition-all duration-300 hover:shadow-[0_0_20px_rgba(157,212,185,0.15)]">
              <div class="aspect-video bg-night flex items-center justify-center p-6">
                <img src={asset.src} alt={asset.label} class="max-w-full max-h-full object-contain group-hover:scale-105 transition-transform duration-300" />
              </div>
              <div class="p-4 flex items-center justify-between">
                <div>
                  <p class="text-snow font-body text-sm font-medium">{asset.label}</p>
                  <p class="text-fade text-xs font-body">{asset.dim}px · PNG</p>
                </div>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-fade group-hover:text-mint transition-colors"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- DISSONANT -->
  <section class="bg-charcoal py-20 px-6 border-b border-fade spotlight-section">
    <div class="max-w-5xl mx-auto">
      <div class="flex items-center gap-6 mb-4 fade-in">
        <img src="/images/press/dissonant/DissonantLogo_800x300.png" alt="Dissonant logo" class="h-12" />
      </div>
      <p class="text-smoke text-base mb-12 max-w-2xl fade-in">A patience test disguised as a game. Control Vil through a mesmerizing realm governed by the all-seeing Observer. Simple mechanics, deliberate difficulty, no hand-holding.</p>

      <!-- Screenshots -->
      <h3 class="font-display text-snow text-[28px] mb-6 fade-in">SCREENSHOTS</h3>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-16 stagger-children">
        {dissonantScreenshots.map(shot => (
          <a href={shot.src} target="_blank" class="group">
            <div class="rounded-xl border border-fade overflow-hidden hover:border-mint transition-all duration-300 hover:shadow-[0_0_20px_rgba(157,212,185,0.15)]">
              <img src={shot.src} alt={shot.label} class="w-full aspect-video object-cover group-hover:scale-105 transition-transform duration-500" />
            </div>
          </a>
        ))}
      </div>

      <!-- Character Art -->
      <h3 class="font-display text-snow text-[28px] mb-6 fade-in">CHARACTER ART</h3>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-16 stagger-children">
        {dissonantCharacters.map(char => (
          <a href={char.src} target="_blank" class="group">
            <div class="bg-surface rounded-xl border border-fade overflow-hidden hover:border-mint transition-all duration-300 hover:shadow-[0_0_20px_rgba(157,212,185,0.15)] p-6 flex flex-col items-center">
              <img src={char.src} alt={char.label} class="h-40 object-contain group-hover:scale-105 transition-transform duration-300" />
              <p class="text-smoke text-xs mt-3 font-body">{char.label}</p>
            </div>
          </a>
        ))}
      </div>

      <!-- Steam Assets -->
      <h3 class="font-display text-snow text-[28px] mb-6 fade-in">STORE ASSETS & CAPSULES</h3>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 stagger-children">
        {dissonantSteam.map(asset => (
          <a href={asset.src} target="_blank" class="group">
            <div class="bg-surface rounded-xl border border-fade overflow-hidden hover:border-mint transition-all duration-300 hover:shadow-[0_0_20px_rgba(157,212,185,0.15)]">
              <div class="aspect-video bg-night flex items-center justify-center p-3">
                <img src={asset.src} alt={asset.label} class="max-w-full max-h-full object-contain group-hover:scale-105 transition-transform duration-300" />
              </div>
              <div class="p-3 flex items-center justify-between">
                <div>
                  <p class="text-snow font-body text-sm font-medium">{asset.label}</p>
                  <p class="text-fade text-xs font-body">{asset.dim}px</p>
                </div>
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-fade group-hover:text-mint transition-colors"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- KRODHA -->
  <section class="bg-charcoal py-20 px-6 border-b border-fade spotlight-section">
    <div class="max-w-5xl mx-auto">
      <div class="flex items-center gap-6 mb-4 fade-in">
        <img src="/images/press/krodha/krodha-logo-800x300.png" alt="Krodha logo" class="h-12" />
      </div>
      <p class="text-smoke text-base mb-12 max-w-2xl fade-in">Anger forged into something worth fighting for. 13 months in the making, featuring an original soundtrack composed specifically for the game.</p>

      <!-- Screenshots -->
      <h3 class="font-display text-snow text-[28px] mb-6 fade-in">SCREENSHOTS</h3>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-16 stagger-children">
        {krodhaScreenshots.map(shot => (
          <a href={shot.src} target="_blank" class="group">
            <div class="rounded-xl border border-fade overflow-hidden hover:border-mint transition-all duration-300 hover:shadow-[0_0_20px_rgba(157,212,185,0.15)]">
              <img src={shot.src} alt={shot.label} class="w-full aspect-video object-cover group-hover:scale-105 transition-transform duration-500" />
            </div>
          </a>
        ))}
      </div>

      <!-- Steam Assets -->
      <h3 class="font-display text-snow text-[28px] mb-6 fade-in">STORE ASSETS & CAPSULES</h3>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 stagger-children">
        {krodhaSteam.map(asset => (
          <a href={asset.src} target="_blank" class="group">
            <div class="bg-surface rounded-xl border border-fade overflow-hidden hover:border-mint transition-all duration-300 hover:shadow-[0_0_20px_rgba(157,212,185,0.15)]">
              <div class="aspect-video bg-night flex items-center justify-center p-3">
                <img src={asset.src} alt={asset.label} class="max-w-full max-h-full object-contain group-hover:scale-105 transition-transform duration-300" />
              </div>
              <div class="p-3 flex items-center justify-between">
                <div>
                  <p class="text-snow font-body text-sm font-medium">{asset.label}</p>
                  <p class="text-fade text-xs font-body">{asset.dim}px</p>
                </div>
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-fade group-hover:text-mint transition-colors"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- BRAND GUIDELINES -->
  <section class="bg-charcoal py-20 px-6 border-b border-fade">
    <div class="max-w-5xl mx-auto fade-in">
      <h2 class="font-display text-snow text-[36px] mb-8">BRAND GUIDELINES</h2>
      <div class="grid md:grid-cols-2 gap-8">
        <div class="bg-surface rounded-xl border border-fade p-8">
          <h3 class="font-body font-semibold text-snow text-lg mb-4">Colors</h3>
          <div class="space-y-3">
            <div class="flex items-center gap-4">
              <div class="w-10 h-10 rounded-lg bg-crimson border border-fade"></div>
              <div>
                <p class="text-snow text-sm font-body font-medium">Crimson</p>
                <p class="text-fade text-xs font-body">#DE1D49</p>
              </div>
            </div>
            <div class="flex items-center gap-4">
              <div class="w-10 h-10 rounded-lg bg-mint border border-fade"></div>
              <div>
                <p class="text-snow text-sm font-body font-medium">Mint</p>
                <p class="text-fade text-xs font-body">#9DD4B9</p>
              </div>
            </div>
            <div class="flex items-center gap-4">
              <div class="w-10 h-10 rounded-lg bg-charcoal border border-fade"></div>
              <div>
                <p class="text-snow text-sm font-body font-medium">Charcoal</p>
                <p class="text-fade text-xs font-body">#1A1A1E</p>
              </div>
            </div>
          </div>
        </div>
        <div class="bg-surface rounded-xl border border-fade p-8">
          <h3 class="font-body font-semibold text-snow text-lg mb-4">Usage Notes</h3>
          <ul class="space-y-3 text-smoke text-sm font-body leading-relaxed">
            <li class="flex gap-2"><span class="text-mint">+</span> Use the logo on dark or crimson backgrounds</li>
            <li class="flex gap-2"><span class="text-mint">+</span> Maintain clear space around the logo</li>
            <li class="flex gap-2"><span class="text-mint">+</span> The "!" is part of the name: always write "!How"</li>
            <li class="flex gap-2"><span class="text-crimson">-</span> Don't stretch, rotate, or recolor the logo</li>
            <li class="flex gap-2"><span class="text-crimson">-</span> Don't place on busy/low-contrast backgrounds</li>
            <li class="flex gap-2"><span class="text-crimson">-</span> Don't use screenshots as logos</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section class="bg-charcoal py-24 px-6">
    <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-5 stagger-children">
      <div class="tilt-card">
        <div class="bg-crimson rounded-2xl p-10 flex flex-col justify-between min-h-[260px] group hover:shadow-[0_0_40px_rgba(222,29,73,0.25)] transition-all duration-500 relative overflow-hidden">
          <div class="absolute -bottom-16 -right-16 w-48 h-48 rounded-full bg-crimson-dark/40 blur-3xl pointer-events-none"></div>
          <div class="relative z-10">
            <div class="w-12 h-12 rounded-xl bg-white/15 flex items-center justify-center mb-6 text-white">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <h3 class="font-display text-white text-[28px] md:text-[36px] leading-tight mb-2">Need Something Else?</h3>
            <p class="font-body text-white/70 text-sm mb-2">For press inquiries, interview requests, or additional assets:</p>
            <p class="font-body text-white text-lg font-medium mb-6">press@howgamestudio.com</p>
            <a href="/contact" class="magnetic-btn inline-flex items-center gap-2 bg-charcoal text-white font-body font-medium text-sm uppercase tracking-[0.1em] rounded-lg px-6 py-3 hover:bg-night transition-colors group/btn">
              Contact Us <span class="inline-block group-hover/btn:translate-x-1 transition-transform">&rarr;</span>
            </a>
          </div>
        </div>
      </div>
      <div class="tilt-card">
        <div class="bg-gradient-to-br from-surface to-night rounded-2xl p-10 border border-fade flex flex-col justify-between min-h-[260px] group hover:border-mint hover:shadow-[0_0_30px_rgba(157,212,185,0.12)] transition-all duration-500">
          <div class="w-12 h-12 rounded-xl bg-mint/10 flex items-center justify-center mb-6 text-mint">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
          </div>
          <div>
            <h3 class="font-body font-semibold text-snow text-xl mb-2">Follow the Studio</h3>
            <p class="text-smoke text-sm font-body mb-6">Devlogs, launch updates, and behind-the-scenes content.</p>
            <SocialLinks color="mint" />
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
