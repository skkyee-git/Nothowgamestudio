---
import BaseLayout from '../layouts/BaseLayout.astro';
import SocialLinks from '../components/SocialLinks.astro';
import team from '../data/team.json';
---

<BaseLayout title="About · !How Game Studio" description="Meet the team behind !How Game Studio. An Indian indie game dev studio.">
  <!-- HERO -->
  <section class="bg-crimson pt-32 pb-20 px-6 text-center relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-16 left-16 w-48 h-48 border border-white/5 rounded-full"></div>
      <div class="absolute bottom-8 right-16 w-32 h-32 border border-white/5 rotate-12"></div>
    </div>
    <h1 class="split-text font-display text-white text-[48px] md:text-[64px] leading-none relative z-10">THE STUDIO BEHIND THE WORLDS</h1>
  </section>

  <!-- STORY -->
  <section class="bg-charcoal py-24 px-6 spotlight-section">
    <div class="max-w-3xl mx-auto">
      <h2 class="split-text font-display text-snow text-[40px] mb-8">OUR STORY</h2>
      <p class="text-smoke text-base leading-relaxed mb-6 fade-in">
        Studio story coming soon. We're collecting our thoughts, not our game's coins.
      </p>
      <p class="text-smoke text-base leading-relaxed fade-in">
        What we can tell you: we're a small indie team from India building games that don't play it safe. We believe in deliberate design, earned difficulty, and the kind of experiences that stay with you after you close the game.
      </p>
    </div>
  </section>

  <hr class="animated-hr" />

  <!-- TEAM -->
  <section class="bg-charcoal py-24 px-6 spotlight-section">
    <div class="max-w-4xl mx-auto">
      <h2 class="split-text font-display text-snow text-[40px] text-center mb-16">THE TEAM</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8 stagger-children">
        {team.map(member => (
          <div class="tilt-card">
            <div class="bg-surface rounded-xl border border-fade p-8 text-center hover:border-mint transition-all duration-500 hover:shadow-[0_0_30px_rgba(157,212,185,0.15)] group">
              <div class="w-28 h-28 rounded-full border-2 border-mint/50 mx-auto mb-6 bg-charcoal flex items-center justify-center group-hover:border-mint group-hover:shadow-[0_0_20px_rgba(157,212,185,0.2)] transition-all duration-500">
                <span class="font-display text-fade text-3xl group-hover:text-mint transition-colors duration-300">{member.name.charAt(0)}</span>
              </div>
              <h3 class="font-body font-semibold text-snow text-lg mb-1">{member.name}</h3>
              <p class="text-smoke text-sm">{member.role}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- MANIFESTO -->
  <section class="bg-crimson py-24 px-6 relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-1/3 left-0 w-full h-px bg-white/5"></div>
      <div class="absolute top-2/3 left-0 w-full h-px bg-white/5"></div>
    </div>

    <div class="max-w-4xl mx-auto space-y-16 relative z-10">
      {[
        "Games should make you feel something you didn't expect.",
        "We'd rather ship one great game than ten forgettable ones.",
        "Every bug is a feature we haven't understood yet."
      ].map((quote, i) => (
        <blockquote class={`text-center ${i % 2 === 0 ? 'fade-in' : i === 1 ? 'fade-in-left' : 'fade-in-right'}`}>
          <p class="font-display text-white text-[32px] md:text-[44px] leading-snug">"{quote}"</p>
        </blockquote>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-charcoal py-20 px-6 text-center spotlight-section">
    <div class="fade-in">
      <a href="/games" class="magnetic-btn inline-block text-mint font-body font-medium text-xl hover:underline transition-all group">
        See what we've built <span class="inline-block group-hover:translate-x-2 transition-transform">&rarr;</span>
      </a>
    </div>
  </section>
</BaseLayout>
