---
import BaseLayout from '../layouts/BaseLayout.astro';
import GameCard from '../components/GameCard.astro';
import SocialLinks from '../components/SocialLinks.astro';
import games from '../data/games.json';

const dissonant = games[0];
const krodha = games[1];

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "!How Game Studio",
  "url": "https://nothowgamestudio.com",
  "logo": "https://nothowgamestudio.com/images/press/studio/logo-square-400x400.png",
  "description": "Indian indie game studio crafting worlds that challenge and inspire.",
  "sameAs": [
    "https://store.steampowered.com/app/3006030/Dissonant/",
    "https://howstudio.itch.io",
    "https://www.youtube.com/channel/UCj3qQEY1lrFdWgDoQJeF7ow",
    "https://www.twitch.tv/nothowstudios",
    "https://discord.gg/Brx2aX2GRF",
    "https://www.linkedin.com/company/nothowgamestudio/"
  ]
};
---

<BaseLayout jsonLd={orgSchema}>
  <!-- HERO -->
  <section class="min-h-screen bg-crimson flex flex-col items-center justify-center text-center px-6 relative overflow-hidden" id="hero">
    <!-- Floating particles -->
    <div class="absolute inset-0 pointer-events-none" id="hero-particles"></div>

    <!-- Content -->
    <div class="relative z-10">
      <h1 class="glitch font-display text-white text-[80px] md:text-[120px] lg:text-[150px] leading-none tracking-wider" data-text="!HOW">!HOW</h1>
      <p class="split-text font-display text-white text-[48px] md:text-[64px] leading-none tracking-wider">GAME STUDIO</p>
      <p class="font-body text-snow text-lg md:text-xl mt-6 font-normal max-w-lg mx-auto opacity-0" id="hero-tagline">We don't make games the way you'd expect.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mt-8 opacity-0" id="hero-buttons">
        <a href="/games" class="magnetic-btn bg-charcoal text-white font-body font-medium text-sm uppercase tracking-[0.1em] rounded-lg px-8 py-3 hover:bg-night transition-colors">SEE OUR GAMES</a>
        <a href="/about" class="magnetic-btn border border-white text-white font-body font-medium text-sm uppercase tracking-[0.1em] rounded-lg px-8 py-3 hover:bg-white hover:text-crimson transition-colors">ABOUT THE STUDIO</a>
      </div>
    </div>

    <div class="absolute bottom-8 opacity-60 animate-bounce-chevron z-10">
      <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
    </div>
  </section>

  <!-- MARQUEE TICKER -->
  <div class="bg-night py-3 overflow-hidden border-y border-fade/30">
    <div class="marquee-track">
      {[...Array(2)].map(() => (
        <div class="flex items-center gap-8 px-4">
          <span class="font-display text-crimson text-lg whitespace-nowrap">DISSONANT</span>
          <span class="text-fade">///</span>
          <span class="font-body text-smoke text-sm whitespace-nowrap uppercase tracking-wider">COMING SOON ON STEAM</span>
          <span class="text-fade">///</span>
          <span class="font-display text-mint text-lg whitespace-nowrap">KRODHA</span>
          <span class="text-fade">///</span>
          <span class="font-body text-smoke text-sm whitespace-nowrap uppercase tracking-wider">EARLY ACCESS SOON</span>
          <span class="text-fade">///</span>
          <span class="font-display text-crimson text-lg whitespace-nowrap">INDIE GAMES MADE DIFFERENT</span>
          <span class="text-fade">///</span>
          <span class="font-body text-smoke text-sm whitespace-nowrap uppercase tracking-wider">NO PUBLISHERS NO COMPROMISES</span>
          <span class="text-fade">///</span>
        </div>
      ))}
    </div>
  </div>

  <!-- FEATURED GAME: KRODHA -->
  <section class="bg-charcoal py-24 px-6 spotlight-section">
    <div class="max-w-5xl mx-auto">
      <div class="fade-in">
        <p class="text-mint uppercase tracking-[0.2em] font-body font-medium text-[13px] mb-4">FEATURED GAME</p>
        <h2 class="split-text font-display text-snow text-[56px] md:text-[72px] leading-none mb-3">KRODHA</h2>
      </div>

      <p class="text-smoke italic text-lg mb-6 fade-in">{krodha.tagline}</p>

      <div class="flex flex-wrap gap-2 mb-8 stagger-children">
        {krodha.genre.map(g => (
          <span class="bg-mint/15 text-mint text-sm px-4 py-1.5 rounded-full font-body border border-mint/20">{g}</span>
        ))}
      </div>

      <div class="grid lg:grid-cols-2 gap-12 items-start">
        <div>
          <p class="text-smoke text-base leading-relaxed mb-8 fade-in">{krodha.description}</p>

          <blockquote class="border-l-4 border-mint pl-6 mb-8 fade-in-left">
            <p class="font-display text-snow text-[28px] md:text-[32px] leading-snug">{krodha.pullQuote}</p>
          </blockquote>

          {krodha.features.length > 0 && (
            <div class="flex flex-wrap gap-2 mb-8 stagger-children">
              {krodha.features.map(f => (
                <span class="bg-surface text-snow text-sm px-4 py-1.5 rounded-full font-body border border-fade/50">{f}</span>
              ))}
            </div>
          )}

          <div class="flex flex-wrap items-center gap-4 fade-in">
            <span class="flex items-center gap-2 text-smoke text-sm bg-surface px-3 py-1.5 rounded-full border border-fade/50">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" class="text-mint"><path d="M11.979 0C5.678 0 .511 4.86.022 11.037l6.432 2.658c.545-.371 1.203-.59 1.912-.59.063 0 .125.004.188.006l2.861-4.142V8.91c0-2.495 2.028-4.524 4.524-4.524 2.494 0 4.524 2.031 4.524 4.527s-2.03 4.525-4.524 4.525h-.105l-4.076 2.911c0 .052.004.105.004.159 0 1.875-1.515 3.396-3.39 3.396-1.635 0-3.016-1.173-3.331-2.727L.436 15.27C1.862 20.307 6.486 24 11.979 24c6.627 0 12.004-5.373 12.004-12S18.606 0 11.979 0z"/></svg>
              Early Access Coming Soon
            </span>
          </div>
        </div>

        <!-- Game art -->
        <div class="scale-in">
          <div class="rounded-xl border border-fade overflow-hidden relative group">
            <img src="/images/games/krodha-01.png" alt="Krodha gameplay screenshot" width="1920" height="1080" class="w-full aspect-video object-cover group-hover:scale-105 transition-transform duration-700" />
            <div class="absolute inset-0 bg-gradient-to-t from-charcoal/60 to-transparent pointer-events-none"></div>
          </div>
          <div class="mt-4">
            <img src="/images/games/krodha-logo.png" alt="Krodha logo" width="800" height="300" class="h-10 opacity-70" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ANIMATED DIVIDER -->
  <hr class="animated-hr" />

  <!-- PHILOSOPHY -->
  <section class="bg-crimson py-24 px-6 relative overflow-hidden">
    <!-- Decorative shapes -->
    <div class="absolute top-10 left-10 w-32 h-32 border border-white/10 rounded-full"></div>
    <div class="absolute bottom-10 right-10 w-48 h-48 border border-white/5 rotate-45"></div>

    <div class="max-w-5xl mx-auto grid md:grid-cols-3 gap-12 stagger-children relative z-10">
      <div class="text-center group">
        <div class="w-16 h-16 rounded-full border-2 border-mint mx-auto mb-5 flex items-center justify-center group-hover:bg-mint/20 transition-colors duration-300 group-hover:scale-110 transform">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#9DD4B9" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
        </div>
        <h3 class="font-body font-semibold text-white text-xl mb-3 uppercase tracking-wider">Independent</h3>
        <p class="font-body text-snow/80 text-base leading-relaxed">No publishers. No compromises. Every pixel is ours.</p>
      </div>
      <div class="text-center group">
        <div class="w-16 h-16 rounded-full border-2 border-mint mx-auto mb-5 flex items-center justify-center group-hover:bg-mint/20 transition-colors duration-300 group-hover:scale-110 transform">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#9DD4B9" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        </div>
        <h3 class="font-body font-semibold text-white text-xl mb-3 uppercase tracking-wider">Crafted</h3>
        <p class="font-body text-snow/80 text-base leading-relaxed">Small team. Big ambition. We build worlds, not products.</p>
      </div>
      <div class="text-center group">
        <div class="w-16 h-16 rounded-full border-2 border-mint mx-auto mb-5 flex items-center justify-center group-hover:bg-mint/20 transition-colors duration-300 group-hover:scale-110 transform">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#9DD4B9" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
        </div>
        <h3 class="font-body font-semibold text-white text-xl mb-3 uppercase tracking-wider">Different</h3>
        <p class="font-body text-snow/80 text-base leading-relaxed">The name says it all. We don't do things the expected way.</p>
      </div>
    </div>
  </section>

  <!-- ALL GAMES PREVIEW -->
  <section class="bg-charcoal py-24 px-6 spotlight-section">
    <div class="max-w-4xl mx-auto">
      <h2 class="split-text font-display text-snow text-[44px] md:text-[52px] text-center mb-16">OUR GAMES</h2>
      <div class="grid md:grid-cols-2 gap-8">
        {games.map(game => (
          <div class="tilt-card fade-in">
            <GameCard
              title={game.title}
              slug={game.slug}
              tagline={game.tagline}
              status={game.status}
              genre={game.genre}
              image={game.cardImage}
            />
          </div>
        ))}
      </div>
      <div class="text-center mt-12 fade-in">
        <a href="/games" class="magnetic-btn inline-block text-mint font-body font-medium hover:underline transition-all text-lg group">
          VIEW ALL GAMES <span class="inline-block group-hover:translate-x-2 transition-transform">&rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-crimson py-24 px-6 relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full bg-crimson-dark/30 blur-3xl"></div>
    </div>

    <div class="max-w-3xl mx-auto text-center relative z-10 fade-in">
      <h2 class="font-display text-white text-[44px] md:text-[56px] leading-tight mb-4">Got a world that needs building?</h2>
      <p class="font-body text-snow/80 text-xl mb-10">Let's talk.</p>
      <a href="/contact" class="magnetic-btn inline-block bg-charcoal text-white font-body font-medium text-sm uppercase tracking-[0.1em] rounded-lg px-10 py-4 hover:bg-night transition-colors mb-10">GET IN TOUCH</a>
      <div class="flex justify-center">
        <SocialLinks color="white" />
      </div>
    </div>
  </section>

  <script>
    // Hero entrance animations
    window.addEventListener('load', () => {
      setTimeout(() => {
        const tagline = document.getElementById('hero-tagline');
        const buttons = document.getElementById('hero-buttons');
        if (tagline) {
          tagline.style.transition = 'opacity 0.8s ease 0.3s';
          tagline.style.opacity = '1';
        }
        if (buttons) {
          buttons.style.transition = 'opacity 0.8s ease 0.6s';
          buttons.style.opacity = '1';
        }
      }, 1400);
    });

    // Hero floating particles
    const particleContainer = document.getElementById('hero-particles');
    if (particleContainer) {
      for (let i = 0; i < 20; i++) {
        const particle = document.createElement('div');
        particle.classList.add('floating-particle');
        particle.style.left = Math.random() * 100 + '%';
        particle.style.animationDuration = (8 + Math.random() * 12) + 's';
        particle.style.animationDelay = (Math.random() * 10) + 's';
        particle.style.animation = `float-up ${8 + Math.random() * 12}s linear ${Math.random() * 10}s infinite`;
        particle.style.width = (2 + Math.random() * 4) + 'px';
        particle.style.height = particle.style.width;
        particleContainer.appendChild(particle);
      }
    }
  </script>
</BaseLayout>
