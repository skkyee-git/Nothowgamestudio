---

<BaseLayout title="Contact · !How Game Studio" description="Get in touch with !How Game Studio.">
  <!-- HERO -->
  <section class="bg-crimson pt-32 pb-20 px-6 text-center relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-20 right-20 w-48 h-48 border border-white/5 rounded-full"></div>
    </div>
    <h1 class="split-text font-display text-white text-[56px] md:text-[72px] leading-none relative z-10">GET IN TOUCH</h1>
    <p class="font-body text-snow/80 text-lg mt-4 relative z-10 fade-in">We'd love to hear from you.</p>
  </section>

  <!-- FORM -->
  <section class="bg-charcoal py-24 px-6 spotlight-section">
    <div class="max-w-2xl mx-auto fade-in">
      <form name="contact" method="POST" data-netlify="true" class="space-y-6">
        <input type="hidden" name="form-name" value="contact" />

        <div class="grid sm:grid-cols-2 gap-6">
          <div>
            <label for="name" class="block text-snow font-body font-medium text-sm mb-2 uppercase tracking-wider">Name</label>
            <input type="text" id="name" name="name" required
              class="w-full bg-surface border border-fade rounded-lg px-4 py-3 text-snow font-body focus:outline-none focus:border-mint focus:shadow-[0_0_15px_rgba(157,212,185,0.1)] transition-all duration-300 placeholder:text-fade"
              placeholder="Your name" />
          </div>
          <div>
            <label for="email" class="block text-snow font-body font-medium text-sm mb-2 uppercase tracking-wider">Email</label>
            <input type="email" id="email" name="email" required
              class="w-full bg-surface border border-fade rounded-lg px-4 py-3 text-snow font-body focus:outline-none focus:border-mint focus:shadow-[0_0_15px_rgba(157,212,185,0.1)] transition-all duration-300 placeholder:text-fade"
              placeholder="your@email.com" />
          </div>
        </div>

        <div>
          <label for="subject" class="block text-snow font-body font-medium text-sm mb-2 uppercase tracking-wider">Subject</label>
          <select id="subject" name="subject"
            class="w-full bg-surface border border-fade rounded-lg px-4 py-3 text-snow font-body focus:outline-none focus:border-mint focus:shadow-[0_0_15px_rgba(157,212,185,0.1)] transition-all duration-300">
            <option value="general">General</option>
            <option value="press">Press</option>
            <option value="business">Business</option>
            <option value="fanmail">Fan Mail</option>
          </select>
        </div>

        <div>
          <label for="message" class="block text-snow font-body font-medium text-sm mb-2 uppercase tracking-wider">Message</label>
          <textarea id="message" name="message" rows="6" required
            class="w-full bg-surface border border-fade rounded-lg px-4 py-3 text-snow font-body focus:outline-none focus:border-mint focus:shadow-[0_0_15px_rgba(157,212,185,0.1)] transition-all duration-300 resize-y placeholder:text-fade"
            placeholder="What's on your mind?"></textarea>
        </div>

        <button type="submit"
          class="magnetic-btn w-full bg-crimson text-white font-body font-semibold text-sm uppercase tracking-[0.15em] rounded-lg px-8 py-4 hover:bg-crimson-dark transition-colors group">
          SEND MESSAGE <span class="inline-block group-hover:translate-x-1 transition-transform">&rarr;</span>
        </button>
      </form>
    </div>
  </section>

  <hr class="animated-hr" />

  <!-- SOCIAL LINKS -->
  <section class="bg-charcoal py-20 px-6 spotlight-section">
    <div class="max-w-4xl mx-auto">
      <h2 class="split-text font-display text-snow text-[36px] text-center mb-12">FIND US ONLINE</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-4 stagger-children">
        {socialPlatforms.map(platform => {
          const url = social[platform.key as keyof typeof social];
          return url ? (
            <a href={url} target="_blank" rel="noopener noreferrer"
              class="tilt-card bg-surface border border-fade rounded-xl p-6 flex flex-col items-center gap-3 hover:border-mint transition-all duration-500 hover:shadow-[0_0_30px_rgba(157,212,185,0.15)] group">
              <span class="text-mint group-hover:text-mint-dark transition-colors group-hover:scale-110 transform duration-300">
                <Fragment set:html={platform.icon} />
              </span>
              <span class="text-snow font-body text-sm font-medium">{platform.label}</span>
              <span class="text-fade text-xs font-body">{platform.desc}</span>
            </a>
          ) : null;
        })}
      </div>
    </div>
  </section>

  <!-- PRESS -->
  <section class="bg-charcoal py-12 px-6 border-t border-fade">
    <div class="max-w-2xl mx-auto text-center fade-in">
      <p class="text-smoke text-base">Need press materials? <a href="/press" class="text-mint font-medium hover:underline">Visit our Press Kit</a> or email us at <span class="text-mint font-medium">press@howgamestudio.com</span></p>
    </div>
  </section>
</BaseLayout>
