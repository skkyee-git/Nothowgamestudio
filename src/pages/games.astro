---
import BaseLayout from '../layouts/BaseLayout.astro';
import SocialLinks from '../components/SocialLinks.astro';
import games from '../data/games.json';

const videoGameSchema = {
  "@context": "https://schema.org",
  "@type": "VideoGame",
  "name": "Dissonant",
  "description": "A patience test disguised as a game. Control Vil through a mesmerizing realm governed by the all-seeing Observer. Simple mechanics you can play with 1 or 2 buttons.",
  "genre": ["Puzzle", "Arcade", "Difficult", "Physics", "Souls-like"],
  "gamePlatform": ["PC", "Steam"],
  "url": "https://store.steampowered.com/app/3006030/Dissonant/",
  "image": "https://nothowgamestudio.com/images/games/dissonant-capsule.png",
  "author": {
    "@type": "Organization",
    "name": "!How Game Studio"
  },
  "operatingSystem": "Windows"
};
---

<BaseLayout title="Games · !How Game Studio" description="Explore games by !How Game Studio. Dissonant, Krodha, and more." jsonLd={videoGameSchema}>
  <!-- HERO -->
  <section class="bg-crimson pt-32 pb-20 px-6 text-center relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-20 right-20 w-64 h-64 border border-white/5 rounded-full"></div>
      <div class="absolute bottom-10 left-10 w-40 h-40 border border-white/5 rotate-45"></div>
    </div>
    <h1 class="split-text font-display text-white text-[64px] md:text-[80px] leading-none relative z-10">OUR GAMES</h1>
    <p class="font-body text-snow/80 text-lg mt-4 relative z-10 fade-in">Every game we make is a statement.</p>
  </section>

  <!-- MARQUEE -->
  <div class="bg-night py-3 overflow-hidden border-y border-fade/30">
    <div class="marquee-track">
      {[...Array(2)].map(() => (
        <div class="flex items-center gap-8 px-4">
          {games.map(g => (
            <>
              <span class="font-display text-crimson text-lg whitespace-nowrap">{g.title.toUpperCase()}</span>
              <span class="text-fade">///</span>
              <span class="font-body text-smoke text-sm whitespace-nowrap uppercase tracking-wider">{g.status.toUpperCase()}</span>
              <span class="text-fade">///</span>
            </>
          ))}
        </div>
      ))}
    </div>
  </div>

  <!-- GAMES -->
  {games.map((game, index) => (
    <>
      <section class="bg-charcoal py-24 px-6 spotlight-section">
        <div class="max-w-6xl mx-auto grid lg:grid-cols-2 gap-16 items-center">
          <!-- Text -->
          <div class={index % 2 !== 0 ? 'lg:order-2' : ''}>
            <p class="text-mint uppercase tracking-[0.2em] font-body font-medium text-[13px] mb-3 fade-in">{game.status.toUpperCase()}</p>
            <h2 class="split-text font-display text-snow text-[52px] md:text-[64px] leading-none mb-4">{game.title.toUpperCase()}</h2>
            <p class="text-smoke italic text-lg mb-6 fade-in">{game.tagline}</p>

            <div class="flex flex-wrap gap-2 mb-6 stagger-children">
              {game.genre.map(g => (
                <span class="bg-mint/15 text-mint text-sm px-4 py-1.5 rounded-full font-body border border-mint/20">{g}</span>
              ))}
            </div>

            <p class="text-smoke text-base leading-relaxed mb-8 fade-in">{game.description}</p>

            {game.features.length > 0 && (
              <div class="flex flex-wrap gap-2 mb-8 stagger-children">
                {game.features.map(f => (
                  <span class="bg-surface text-snow text-sm px-4 py-1.5 rounded-full font-body border border-fade/50">{f}</span>
                ))}
              </div>
            )}

            <blockquote class="border-l-4 border-mint pl-6 mb-8 fade-in-left">
              <p class="font-display text-snow text-[24px] md:text-[30px] leading-snug">{game.pullQuote}</p>
            </blockquote>

            {game.playerQuote && (
              <div class="bg-surface/50 rounded-lg p-4 border border-fade/50 mb-8 fade-in">
                <p class="text-smoke italic text-sm">"{game.playerQuote}"</p>
              </div>
            )}

            <div class="flex flex-wrap gap-4 fade-in">
              {game.storeLinks.steam && (
                <a href={game.storeLinks.steam} target="_blank" rel="noopener noreferrer" class="magnetic-btn bg-crimson text-white font-body font-medium text-sm uppercase tracking-[0.1em] rounded-lg px-8 py-3 hover:bg-crimson-dark transition-colors">WISHLIST ON STEAM</a>
              )}
              {game.storeLinks.itch && (
                <a href={game.storeLinks.itch} target="_blank" rel="noopener noreferrer" class="magnetic-btn border border-mint text-mint font-body font-medium text-sm uppercase tracking-[0.1em] rounded-lg px-8 py-3 hover:bg-mint hover:text-charcoal transition-colors">PLAY ON ITCH.IO</a>
              )}
            </div>

            {game.madeWith && (
              <p class="text-fade text-sm mt-6 fade-in">Made with {game.madeWith}</p>
            )}
          </div>

          <!-- Game art -->
          <div class={`scale-in ${index % 2 !== 0 ? 'lg:order-1' : ''}`}>
            <div class="space-y-4">
              <div class="rounded-xl border border-fade overflow-hidden relative group">
                <img src={game.screenshots[0]} alt={`${game.title} screenshot`} width="1920" height="1080" class="w-full aspect-video object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" />
                <div class="absolute inset-0 bg-gradient-to-t from-charcoal/50 to-transparent pointer-events-none"></div>
              </div>
              {game.screenshots.length > 1 && (
                <div class="grid grid-cols-3 gap-2">
                  {game.screenshots.slice(1, 4).map(src => (
                    <div class="rounded-lg border border-fade/50 overflow-hidden group">
                      <img src={src} alt={`${game.title} screenshot`} width="1920" height="1080" class="w-full aspect-video object-cover group-hover:scale-110 transition-transform duration-500" loading="lazy" />
                    </div>
                  ))}
                </div>
              )}
              <img src={game.logo} alt={`${game.title} logo`} width="800" height="300" class="h-8 opacity-60" loading="lazy" />
            </div>
          </div>
        </div>
      </section>

      {index < games.length - 1 && (
        <div class="h-1 bg-gradient-to-r from-transparent via-crimson to-transparent"></div>
      )}
    </>
  ))}

  <!-- CTA -->
  <section class="bg-charcoal py-24 px-6">
    <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-5 stagger-children">
      <div class="tilt-card">
        <div class="bg-crimson rounded-2xl p-10 flex flex-col justify-between min-h-[240px] group hover:shadow-[0_0_40px_rgba(222,29,73,0.25)] transition-all duration-500 relative overflow-hidden">
          <div class="absolute -bottom-16 -right-16 w-48 h-48 rounded-full bg-crimson-dark/40 blur-3xl pointer-events-none"></div>
          <div class="relative z-10">
            <div class="w-12 h-12 rounded-xl bg-white/15 flex items-center justify-center mb-6 text-white">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2v4m0 12v4M4.93 4.93l2.83 2.83m8.48 8.48l2.83 2.83M2 12h4m12 0h4M4.93 19.07l2.83-2.83m8.48-8.48l2.83-2.83"/></svg>
            </div>
            <h3 class="font-display text-white text-[32px] md:text-[40px] leading-tight mb-2">More games in the forge.</h3>
            <p class="font-body text-white/70 text-base mb-6">Follow us to stay in the loop.</p>
            <div>
              <SocialLinks color="white" />
            </div>
          </div>
        </div>
      </div>
      <div class="tilt-card">
        <div class="bg-gradient-to-br from-surface to-night rounded-2xl p-10 border border-fade flex flex-col justify-between min-h-[240px] group hover:border-mint hover:shadow-[0_0_30px_rgba(157,212,185,0.12)] transition-all duration-500">
          <div class="w-12 h-12 rounded-xl bg-mint/10 flex items-center justify-center mb-6 text-mint">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          </div>
          <div>
            <h3 class="font-body font-semibold text-snow text-xl mb-2">Want to collaborate?</h3>
            <p class="text-smoke text-sm font-body mb-6">Press, business, or fan mail. We'd love to hear from you.</p>
            <a href="/contact" class="magnetic-btn inline-flex items-center gap-2 border border-mint text-mint font-body font-medium text-sm uppercase tracking-[0.1em] rounded-lg px-6 py-3 hover:bg-mint hover:text-charcoal transition-colors group/btn">
              Contact Us <span class="inline-block group-hover/btn:translate-x-1 transition-transform">&rarr;</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
