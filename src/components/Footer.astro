---
import SocialLinks from './SocialLinks.astro';

const links = [
  { href: '/games', label: 'Games' },
  { href: '/about', label: 'About' },
  { href: '/press', label: 'Press Kit' },
  { href: '/contact', label: 'Contact' },
];
---

<footer class="bg-charcoal py-16">
  <div class="max-w-6xl mx-auto px-6 text-center">
    <p class="font-display text-snow text-2xl tracking-wider mb-6">!HOW GAME STUDIO</p>

    <div class="flex items-center justify-center gap-6 mb-6">
      {links.map((link, i) => (
        <>
          <a href={link.href} class="text-smoke hover:text-mint transition-colors text-sm font-body">{link.label}</a>
          {i < links.length - 1 && <span class="text-fade">|</span>}
        </>
      ))}
    </div>

    <div class="flex justify-center mb-8">
      <SocialLinks color="mint" />
    </div>

    <div class="border-t border-fade pt-6 flex flex-col sm:flex-row items-center justify-between gap-2">
      <p class="text-smoke/70 text-sm">&copy; 2026 !How Game Studio</p>
      <p class="text-smoke/70 text-sm">Designed by Skkyee</p>
    </div>
  </div>
</footer>
