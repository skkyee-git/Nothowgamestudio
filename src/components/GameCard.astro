---
interface Props {
  title: string;
  slug: string;
  tagline: string;
  status: string;
  genre: string[];
  image?: string;
}

const { title, slug, tagline, status, genre, image } = Astro.props;

const statusLabel = status.includes('Coming Soon') ? 'Coming Soon' : 'In Development';
---

<div class="bg-surface rounded-xl overflow-hidden border border-fade hover:-translate-y-2 hover:border-mint transition-all duration-500 hover:shadow-[0_0_30px_rgba(157,212,185,0.2)] group cursor-pointer">
  <!-- Image -->
  <div class="aspect-video bg-charcoal relative overflow-hidden">
    {image ? (
      <img src={image} alt={`${title} screenshot`} width="920" height="430" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" />
    ) : (
      <div class="w-full h-full flex items-center justify-center">
        <span class="font-display text-snow/10 text-4xl tracking-[0.3em] group-hover:text-snow/25 group-hover:tracking-[0.5em] transition-all duration-700">{title.toUpperCase()}</span>
      </div>
    )}
    <div class="absolute inset-0 bg-gradient-to-t from-surface/80 to-transparent pointer-events-none"></div>
    <!-- Corner accents -->
    <div class="absolute top-3 left-3 w-6 h-6 border-t-2 border-l-2 border-mint/0 group-hover:border-mint/50 transition-all duration-500"></div>
    <div class="absolute bottom-3 right-3 w-6 h-6 border-b-2 border-r-2 border-mint/0 group-hover:border-mint/50 transition-all duration-500"></div>
  </div>
  <div class="p-6">
    <div class="flex items-center justify-between mb-3">
      <h3 class="font-display text-snow text-2xl">{title.toUpperCase()}</h3>
      <span class="bg-mint/15 text-mint text-xs font-body px-3 py-1 rounded-full border border-mint/20 whitespace-nowrap">
        {statusLabel}
      </span>
    </div>
    <p class="text-smoke text-[15px] mb-4 leading-relaxed">{tagline}</p>
    <div class="flex flex-wrap gap-2">
      {genre.map(g => (
        <span class="bg-charcoal text-smoke text-xs px-2.5 py-1 rounded-full font-body border border-fade/50 group-hover:text-mint group-hover:border-mint/30 transition-colors duration-300">{g}</span>
      ))}
    </div>
  </div>
</div>
