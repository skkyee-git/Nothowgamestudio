  { key: 'linkedin', label: 'LinkedIn', icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>` },
  { key: 'itch', label: 'Itch.io', icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M3.13 1.338C2.08 1.96.02 4.328 0 4.95v1.03c0 1.303 1.22 2.45 2.325 2.45 1.33 0 2.436-1.1 2.436-2.41 0 1.31 1.07 2.41 2.4 2.41 1.33 0 2.4-1.1 2.4-2.41 0 1.31 1.13 2.41 2.46 2.41h.01c1.33 0 2.46-1.1 2.46-2.41 0 1.31 1.07 2.41 2.4 2.41 1.33 0 2.4-1.1 2.4-2.41 0 1.31 1.1 2.41 2.44 2.41 1.1 0 2.32-1.147 2.32-2.45v-1.03c-.02-.62-2.08-2.99-3.13-3.612C18.48.822 14.97.5 12 .5c-2.97 0-6.48.322-8.87 0.838zM12 8.31c-.63.09-1.18.49-1.56.89-.38-.4-.93-.8-1.56-.89-.63.09-1.18.49-1.56.89-.38-.4-.93-.8-1.56-.89-1 .14-1.82.86-2.22 1.65-.52 1.06-.6 2.68-.58 3.3.1 3.47.14 5.94.45 7.55.2 1.03 1.2 2.13 3.3 2.62 1.8.43 4.7.43 5.29.43.59 0 3.49 0 5.29-.43 2.1-.49 3.1-1.59 3.3-2.62.31-1.61.35-4.08.45-7.55.02-.62-.06-2.24-.58-3.3-.4-.79-1.22-1.51-2.22-1.65-.63.09-1.18.49-1.56.89-.38-.4-.93-.8-1.56-.89-.63.09-1.18.49-1.56.89-.38-.4-.93-.8-1.56-.89zm-2.77 4.45h1.71l.56 2.09.56-2.09h1.71l-1.43 3.98v2.77h-1.68v-2.77z"/></svg>` },
  { key: 'steam', label: 'Steam', icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M11.979 0C5.678 0 .511 4.86.022 11.037l6.432 2.658c.545-.371 1.203-.59 1.912-.59.063 0 .125.004.188.006l2.861-4.142V8.91c0-2.495 2.028-4.524 4.524-4.524 2.494 0 4.524 2.031 4.524 4.527s-2.03 4.525-4.524 4.525h-.105l-4.076 2.911c0 .052.004.105.004.159 0 1.875-1.515 3.396-3.39 3.396-1.635 0-3.016-1.173-3.331-2.727L.436 15.27C1.862 20.307 6.486 24 11.979 24c6.627 0 12.004-5.373 12.004-12S18.606 0 11.979 0z"/></svg>` },
];
---

<div class={`flex items-center flex-wrap ${sizeClass}`}>
  {platforms.map(platform => {
    const url = social[platform.key as keyof typeof social];
    return url ? (
      <a
        href={url}
        target="_blank"
        rel="noopener noreferrer"
        class={`${colorClass} transition-colors duration-200`}
        aria-label={platform.label}
      >
        <Fragment set:html={platform.icon} />
      </a>
    ) : null;
  })}
</div>
