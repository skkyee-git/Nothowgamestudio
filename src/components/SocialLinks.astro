---
import social from '../data/social.json';

interface Props {
  color?: 'mint' | 'white' | 'snow';
  size?: 'sm' | 'md';
}

const { color = 'mint', size = 'md' } = Astro.props;

const colorClass = color === 'mint' ? 'text-mint hover:text-mint-dark' : 'text-snow hover:text-white';
const sizeClass = size === 'sm' ? 'text-sm gap-4' : 'text-base gap-6';

